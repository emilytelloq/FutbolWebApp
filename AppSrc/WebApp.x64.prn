37853>>>>>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37856>>>>>>>        Case Begin
37856>>>>>>>            Case (NavigateData.eNavigateType = nfFromMain)
37858>>>>>>>                // If from main, this is a propbably a main file Select to Zoom.
37858>>>>>>>                Case Break
37859>>>>>>>
37859>>>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
37862>>>>>>>                // If from parent, this is a constrained drill down.
37862>>>>>>>                Case Break
37863>>>>>>>
37863>>>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
37866>>>>>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37866>>>>>>>                Case Break
37867>>>>>>>
37867>>>>>>>            Case Else // must be nfUndefined
37867>>>>>>>
37867>>>>>>>        Case End
37867>>>>>>>
37867>>>>>>>        Send SetActionButtons
37868>>>>>>>
37868>>>>>>>    End_Procedure
37869>>>>>>>
37869>>>>>>>End_Object 
