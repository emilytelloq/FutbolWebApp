37825>>>>>>>    Procedure SetActionButtons
37828>>>>>>>        tWebNavigateData NavigateData
37828>>>>>>>        tWebNavigateData NavigateData
37828>>>>>>>        Boolean bHasRecord
37828>>>>>>>        Handle hoDD
37828>>>>>>>
37828>>>>>>>        Get Server to hoDD
37829>>>>>>>        Get GetNavigateData to NavigateData
37830>>>>>>>        Get HasRecord of hoDD to bHasRecord
37831>>>>>>>
37831>>>>>>>        // let's hide all buttons and then Show the ones we want
37831>>>>>>>        WebSet pbRender of oEditBtn to False
37832>>>>>>>        WebSet pbRender of oSaveBtn to False
37833>>>>>>>        WebSet pbRender of oCancelChangesBtn to False
37834>>>>>>>        WebSet pbRender of oDeleteBtn to False
37835>>>>>>>
37835>>>>>>>        If (NavigateData.bReadOnly) Begin
37837>>>>>>>            WebSet pbRender of oEditBtn to True
37838>>>>>>>        End
37838>>>>>>>>
37838>>>>>>>        Else Begin
37839>>>>>>>            WebSet pbRender of oSaveBtn to True
37840>>>>>>>            WebSet pbRender of oCancelChangesBtn to True
37841>>>>>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37842>>>>>>>        End
37842>>>>>>>>
37842>>>>>>>    End_Procedure
37843>>>>>>>
37843>>>>>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37846>>>>>>>        // Close after save
37846>>>>>>>        Send NavigateClose Self
37847>>>>>>>    End_Procedure
37848>>>>>>>
37848>>>>>>>    // this will close the view after a delete
37848>>>>>>>    Procedure OnViewDeleted Handle hoDDO
37851>>>>>>>        Send NavigateClose Self
37852>>>>>>>    End_Procedure
