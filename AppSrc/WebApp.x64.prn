37553>>>>>>>
37553>>>>>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37556>>>>>>>        Case Begin
37556>>>>>>>            Case (NavigateData.eNavigateType = nfFromMain)
37558>>>>>>>                // If from main, this is a propbably a main file Select to Zoom.
37558>>>>>>>                Case Break
37559>>>>>>>
37559>>>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
37562>>>>>>>                // If from parent, this is a constrained drill down.
37562>>>>>>>                Case Break
37563>>>>>>>
37563>>>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
37566>>>>>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37566>>>>>>>                Case Break
37567>>>>>>>
37567>>>>>>>            Case Else // must be nfUndefined
37567>>>>>>>
37567>>>>>>>        Case End
37567>>>>>>>
37567>>>>>>>        Send SetActionButtons
37568>>>>>>>
37568>>>>>>>    End_Procedure
37569>>>>>>>
37569>>>>>>>End_Object 
