37525>>>>>>>    Procedure SetActionButtons
37528>>>>>>>        tWebNavigateData NavigateData
37528>>>>>>>        tWebNavigateData NavigateData
37528>>>>>>>        Boolean bHasRecord
37528>>>>>>>        Handle hoDD
37528>>>>>>>
37528>>>>>>>        Get Server to hoDD
37529>>>>>>>        Get GetNavigateData to NavigateData
37530>>>>>>>        Get HasRecord of hoDD to bHasRecord
37531>>>>>>>
37531>>>>>>>        // let's hide all buttons and then Show the ones we want
37531>>>>>>>        WebSet pbRender of oEditBtn to False
37532>>>>>>>        WebSet pbRender of oSaveBtn to False
37533>>>>>>>        WebSet pbRender of oCancelChangesBtn to False
37534>>>>>>>        WebSet pbRender of oDeleteBtn to False
37535>>>>>>>
37535>>>>>>>        If (NavigateData.bReadOnly) Begin
37537>>>>>>>            WebSet pbRender of oEditBtn to True
37538>>>>>>>        End
37538>>>>>>>>
37538>>>>>>>        Else Begin
37539>>>>>>>            WebSet pbRender of oSaveBtn to True
37540>>>>>>>            WebSet pbRender of oCancelChangesBtn to True
37541>>>>>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37542>>>>>>>        End
37542>>>>>>>>
37542>>>>>>>    End_Procedure
37543>>>>>>>
37543>>>>>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37546>>>>>>>        // Close after save
37546>>>>>>>        Send NavigateClose Self
37547>>>>>>>    End_Procedure
37548>>>>>>>
37548>>>>>>>    // this will close the view after a delete
37548>>>>>>>    Procedure OnViewDeleted Handle hoDDO
